#include <stdio.h>

int main() {

    void *sensor;   // generic pointer
    int vibrations = 847;
    sensor = &vibrations;

    printf("Vibrations: %d\n", *(int *)sensor);
    printf("Address: %p\n\n", (void *)sensor);

    float temperature = 73.6;
    sensor = &temperature;

    printf("Temperature: %.1f\n", *(float *)sensor);
    printf("Address: %p\n\n", (void *)sensor);

    char status = 'W';
    sensor = &status;

    printf("Status: %c\n", *(char *)sensor);
    printf("Address: %p\n\n", (void *)sensor);

    if (*(char *)sensor == 'N') {
        printf("System is Normal\n");
    }
    else if (*(char *)sensor == 'W') {
        printf("Warning! Check system\n");
    }
    else if (*(char *)sensor == 'C') {
        printf("Critical condition!\n");
    }

    return 0;
}
