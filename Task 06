#include <stdio.h>

float totalRevenue(float arr[], int n) {
    float sum = 0;
    for(int i=0;i<n;i++) 
    sum += arr[i];
    return sum;
}

int bestTable(float arr[], int n) {
    int idx = 0;
    for(int i=1;i<n;i++){
        if(arr[i] > arr[idx]){
        idx = i;
        }
    }
    return idx;
}

int isProfitable(float total) {
    if(total > 10000){
    return 1;
    }
    else 
    return 0;
}

int main() {
    float bills[5];

    for(int i=0;i<5;i++) {
        printf("Enter bill: ");
        scanf("%f",&bills[i]);
    }

    float total = totalRevenue(bills,5);
    int best = bestTable(bills,5);

    printf("Total: %.2f\n", total);
    printf("Best Table: %d\n", best+1);

    if(isProfitable(total))
        printf("Profitable\n");
    else
        printf("Not Profitable\n");

    return 0;
}
