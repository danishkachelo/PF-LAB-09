#include <stdio.h>

int basicAttack(int dmg, int hp) {
    return hp - dmg;
}

int powerStrike(int dmg, int hp) {
    return hp - (int)(dmg * 2.5);
}

int heal(int dmg, int hp) {
    return hp + 20;
}

int poisonAttack(int dmg, int hp) {
    printf("Poison effect!\n");
    return hp - (dmg/2);
}

int main() {
    int hp = 100, dmg = 25, choice;
    int (*action)(int,int);

    for(int i=0;i<3;i++) {
        printf("\n1.Basic 2.Power 3.Heal 4.Poison\n");
        scanf("%d",&choice);

        if(choice==1) action = basicAttack;
        else if(choice==2) action = powerStrike;
        else if(choice==3) action = heal;
        else action = poisonAttack;

        hp = action(dmg, hp);
        printf("HP: %d\n", hp);
    }

    return 0;
}
