#include <stdio.h>

int totalRuns(int arr[], int size);
int highestScore(int arr[], int size);
int aboveAverage(int arr[], int size);
int main() {
    int arr[10];
    int runs;
    printf("Enter the socre of match:\n");
    for(int i = 0; i < 10; i++){
        scanf("%d", &runs);
        arr[i] = runs;
    }
    totalRuns(arr, 10);
    highestScore(arr, 10);
    aboveAverage(arr, 10);
    
    return 0;
}
int totalRuns(int arr[], int size){
    double count = 0;
    float average = 0;
    for(int i = 0; i < 10; i++){
        count += arr[i];
    }
    average = count / 10;
    printf("Total runs: %.2lf\n", count);
    printf("average: %.2f\n", average);
    return count;
}
int highestScore(int arr[], int size){
    int maximum = arr[0];
    for(int i = 0; i < 10; i++){
        if(arr[i] > maximum){
            maximum = arr[i];
        }
    }
    printf("highest score: %d\n", maximum);
    return maximum;
}
int aboveAverage(int arr[], int size){
    float average = 0;
    int aboveaverage = 0;
    int count = 0;
    for(int i = 0; i < 10; i++){
        count += arr[i];
    }
    average = count / 10;
    for(int i = 0; i < 10; i++){
        if(average < arr[i]){
            aboveaverage++;
        }
    }
    printf("Above average: %d\n ", aboveaverage);
    return aboveaverage;
}
