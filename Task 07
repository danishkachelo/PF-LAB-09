#include <stdio.h>

int main() {
    int arr[6] = {40, 50, 60, 30, 20, 45};
    int *p = arr;
    int max = *p;

    for(int i=0;i<6;i++)
        if(*(p+i) > max) max = *(p+i);

    printf("Before:\n");
    for(int i=0;i<6;i++)
        printf("%d ", *(p+i));

    for(int i=0;i<6;i++)
        *(p+i) = (int)(((float)*(p+i)/max)*100);

    printf("\nAfter:\n");
    for(int i=0;i<6;i++)
        printf("%d ", *(p+i));

    return 0;
}
